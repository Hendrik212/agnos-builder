--- a/arch/arm64/boot/dts/qcom/comma_common.dtsi
+++ b/arch/arm64/boot/dts/qcom/comma_common.dtsi
@@ -1,3 +1,4 @@
+/* ABRP BLE: Enable Bluetooth UART and WCN3990-BT HCI driver */

 /* debug UART */
 &qupv3_se9_2uart {
@@ -5,6 +6,29 @@
   status = "ok";
 };

+/* Bluetooth UART (SE6 4-wire UART with flow control) */
+&qupv3_se6_4uart {
+  status = "ok";
+
+  bluetooth {
+    compatible = "qcom,wcn3990-bt";
+
+    /* Power supplies from existing bt_wcn3990 node */
+    vddio-supply = <&pm8998_s3>;
+    vddxo-supply = <&pm8998_s5>;
+    vddrf-supply = <&pm8998_l7>;
+    vddch0-supply = <&pm8998_l17>;
+    vddch1-supply = <&pm8998_l25>;
+
+    /* Max baudrate for WCN3990 */
+    max-speed = <3200000>;
+
+    /* Firmware path (relative to /lib/firmware/) */
+    firmware-name = "qca/crbtfw21.tlv";
+  };
+};
+
 &qupv3_se5_spi {
   status = "disabled";
 };
